{
  "name": "vendor/pachy-app",
  "description": "pachy application",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "nikic/fast-route": "^1.3",
    "vlucas/phpdotenv": "^5.6",
    "firebase/php-jwt": "^7.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Core\\": "core/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php -r \"if (!file_exists('.env') && file_exists('.env.example')) { copy('.env.example', '.env'); echo '.env created from .env.example\\n'; }\""
    ]
  }
}
